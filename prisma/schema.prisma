// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model LoanRequest {
  id            String   @id @default(uuid())
  practiceId    String   @unique
  importo       Float
  durata        Int
  impiego       String
  nome          String
  cognome       String
  email         String
  telefono      String
  codiceFiscale String
  reddito       Float?
  finalita      String?
  anzianita     Int?
  analyticsSessionId String?
  sourcePage    String?
  privacyAccepted Boolean @default(false)
  crifAccepted    Boolean @default(false)
  status        String   @default("IN_REVISIONE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(uuid())
  nome      String
  email     String
  oggetto   String
  message   String
  analyticsSessionId String?
  sourcePage String?
  status    String   @default("UNREAD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AnalyticsEvent {
  id          String   @id @default(uuid())
  eventType   String
  page        String
  label       String?
  value       Float?
  sessionId   String?
  metadata    String?
  createdAt   DateTime @default(now())

  @@index([eventType, createdAt])
  @@index([page, createdAt])
  @@index([sessionId, createdAt])
}
